; ── Skill Pad ─ bottom-right ─────────────────────────────────────────────────
; AttackBtn mirrors the joystick: 192×192, same margins (14 right, 54 bottom).
; 3 skill buttons (64×64) arc around it at radius 130.
;
; Container: 300×320  (offset -314 / -374 / -14 / -54 from bottom-right)
; Attack screen pos unchanged — container expanded 20px left, attack shifted 20px right inside it.
; Skill radius = 140px from attack centre → gap = 140−77−32 = 31px clear space.
; Local coords (origin = top-left of SkillPad):
;   AttackBtn  : (107,127)–(261,281)  centre (184,204)   154×154
;   TornadoBtn : (152, 32)–(216, 96)  270° / directly above   64×64
;   SkyDropBtn : ( 53, 73)–(117,137)  225° / upper-left        64×64
;   ThrowBtn   : ( 12,172)–( 76,236)  180° / left              64×64
[node name="SkillPad" type="Control" parent="."]
anchor_left = 1.0
anchor_top = 1.0
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = -314.0
offset_top = -374.0
offset_right = -14.0
offset_bottom = -54.0

