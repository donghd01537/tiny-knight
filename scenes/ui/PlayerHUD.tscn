[node name="PlayerHUD" type="CanvasLayer"]
script = ExtResource("1_hud")

; ── Virtual Joystick ─ dynamic position ──────────────────────────────────────
; Hidden by default. PlayerHUD spawns it at the first touch position.
; Fixed size 192×192 so begin() can compute center correctly.
[node name="Joystick" type="Control" parent="."]
script = ExtResource("2_joystick")
anchor_left = 0.0
anchor_top = 0.0
anchor_right = 0.0
anchor_bottom = 0.0
offset_left = 0.0
offset_top = 0.0
offset_right = 192.0
offset_bottom = 192.0
modulate = Color(1, 1, 1, 0.35)

[node name="Base" type="TextureRect" parent="Joystick"]
